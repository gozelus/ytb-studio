# Copy this file to .dev.vars and fill in your Gemini API key.
# .dev.vars is gitignored — never commit real keys.
#
# Get a key at: https://aistudio.google.com/app/apikey
# Free tier: 20 req/day per model. Enable billing for production use.

GEMINI_API_KEY=your-gemini-api-key-here
SHARECODE=change-this-sharecode

# Optional: cascading model fallback on overload/quota (comma-separated).
# When the current model returns 503/overloaded/quota, the next is tried automatically.
# Default: gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro
# GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro

# Optional: pin a single model (overridden by GEMINI_MODELS if both are set)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: long-video segmentation fallback after Gemini stalls or hits context limits.
# Still uses Gemini fileData + videoMetadata; no YouTube fetching is performed.
# LONG_VIDEO_FIRST_SEGMENT_SECONDS=300
# LONG_VIDEO_SEGMENT_SECONDS=900
# LONG_VIDEO_MAX_SEGMENTS=16
